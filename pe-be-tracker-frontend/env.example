# Sample environment variables for pe-be-tracker-frontend
# Rename or copy this file to `.env.development`, `.env.production`, etc.

VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_API_TIMEOUT=10000
VITE_ENABLE_LOGGING=true

# PostHog Analytics Configuration
# Get these values from your PostHog project settings
VITE_PUBLIC_POSTHOG_KEY=your_posthog_api_key_here
VITE_PUBLIC_POSTHOG_HOST=https://app.posthog.com 
# Test environment variables for pe-be-tracker-frontend
# This file is loaded when running `npm run dev:test`

# API Configuration
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_API_TIMEOUT=10000

# Environment
VITE_ENVIRONMENT=development

# Google OAuth (test values)
VITE_GOOGLE_CLIENT_ID=test-client-id

# PostHog Analytics (test values)
VITE_PUBLIC_POSTHOG_KEY=test-key
VITE_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Logging (enabled for debugging tests)
VITE_ENABLE_LOGGING=true

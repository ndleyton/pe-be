# Copy this file to backend/.env.production before deploying.
# This file is used by both the backend container and docker compose.

# Public hostnames
FRONTEND_URL=https://app.example.com
FRONTEND_POST_LOGIN_PATH=/workouts
API_ORIGIN_DOMAIN=origin-api.example.com
GOOGLE_REDIRECT_URI=https://app.example.com/api/v1/auth/google/callback
# Optional regex for ephemeral preview hosts. Keep this narrow.
# ADDITIONAL_CORS_ALLOWED_ORIGIN_REGEX=https://preview-[a-z0-9-]+\\.example\\.com

# Backend runtime
ENVIRONMENT=production
LOG_LEVEL=INFO
SECRET_KEY=replace-with-a-long-random-secret
JWT_LIFETIME_SECONDS=604800
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
# Leave COOKIE_DOMAIN unset unless you prove cross-subdomain cookies are required.
# COOKIE_DOMAIN=.example.com

# Database container settings
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=replace-with-a-strong-db-password

# Backend connection string. Keep the host as "db" for docker compose networking.
DATABASE_URL=postgresql+asyncpg://app:replace-with-a-strong-db-password@db:5432/app

# Google OAuth
GOOGLE_CLIENT_ID=replace-with-your-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-your-google-client-secret

# Optional AI / tracing integrations
GOOGLE_AI_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# Caddy ingress / edge throttling
# Add the public CIDRs of trusted upstream proxies so
# Caddy can derive {client_ip} from X-Forwarded-For instead of rate-limiting
# the proxy egress address.
CADDY_TRUSTED_PROXIES=
EDGE_AUTH_READ_RATE_LIMIT_EVENTS=120
EDGE_AUTH_READ_RATE_LIMIT_WINDOW=1m
EDGE_AUTH_WRITE_RATE_LIMIT_EVENTS=20
EDGE_AUTH_WRITE_RATE_LIMIT_WINDOW=10m
EDGE_PUBLIC_READ_RATE_LIMIT_EVENTS=180
EDGE_PUBLIC_READ_RATE_LIMIT_WINDOW=1m
EDGE_HEALTH_RATE_LIMIT_EVENTS=60
EDGE_HEALTH_RATE_LIMIT_WINDOW=1m

# Scheduled backend jobs
JOB_CHAT_ATTACHMENT_CLEANUP_ENABLED=true
JOB_CLOSE_STALE_OPEN_WORKOUTS_ENABLED=true
JOB_CLOSE_STALE_OPEN_WORKOUTS_MAX_AGE_HOURS=24

# OpenTelemetry (Grafana / OTLP)
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS="Authorization=Basic%20..."
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_LOG_LEVEL=debug
OTEL_SERVICE_NAME=app-backend
OTEL_SERVICE_VERSION=
OTEL_TRACES_SAMPLER_ARG=1.0

# Optional app settings
IMAGE_URL_PREFIX=https://images.example-cdn.com/exercises/
IMPORT_DATABASE_HOST=localhost
IMPORT_DATABASE_PORT=5432
IMPORT_DATABASE_NAME=
IMPORT_DATABASE_USER=
IMPORT_DATABASE_PASSWORD=

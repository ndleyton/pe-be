# Backend environment example

# Security
SECRET_KEY=change-me
JWT_LIFETIME_SECONDS=604800
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=.yourdomain.com

# OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Import database configuration (for external data sources)
IMPORT_DATABASE_HOST=localhost
IMPORT_DATABASE_PORT=5432
IMPORT_DATABASE_NAME=gym_tracker_development
IMPORT_DATABASE_USER=postgres
IMPORT_DATABASE_PASSWORD=your-import-db-password
# Image Configuration
IMAGE_URL_PREFIX=https://raw.githubusercontent.com/yuhonas/free-exercise-db/main/exercises/

# Cookie settings

FRONTEND_URL=http://localhost:5173
FRONTEND_POST_LOGIN_PATH=/workouts

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pe_be

# Environment
ENVIRONMENT=development

# Jobs
JOB_CHAT_ATTACHMENT_CLEANUP_ENABLED=true

# OpenTelemetry / Grafana Cloud traces
OTEL_ENABLED=false
OTEL_SERVICE_NAME=pe-be-backend
OTEL_SERVICE_VERSION=
# Example: https://otlp-gateway-prod-us-central-0.grafana.net/otlp
OTEL_EXPORTER_OTLP_ENDPOINT=
# Optional traces-specific override if you don't want the shared OTLP endpoint
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
# Example: Authorization=Basic%20<base64(instance_id:token)>
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_TRACES_SAMPLER_ARG=0.1
OTEL_EXCLUDED_URLS=/health

# Copy this file to backend/.env for local development.

# Core app settings
ENVIRONMENT=development
SECRET_KEY=test-secret-key
GOOGLE_CLIENT_ID=test-google-client-id
GOOGLE_CLIENT_SECRET=test-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
FRONTEND_URL=http://localhost:5173
FRONTEND_POST_LOGIN_PATH=/workouts
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pe_be

# Optional integrations
API_VERSION=v1
OPENAI_API_KEY=
GOOGLE_AI_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com
IMAGE_URL_PREFIX=

# Cookie/session settings
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
JWT_LIFETIME_SECONDS=604800

# Local import database settings
IMPORT_DATABASE_HOST=localhost
IMPORT_DATABASE_PORT=5432
IMPORT_DATABASE_NAME=gym_tracker_development
IMPORT_DATABASE_USER=postgres
IMPORT_DATABASE_PASSWORD=postgres

# Job toggles
JOB_CHAT_ATTACHMENT_CLEANUP_ENABLED=true
JOB_CLOSE_STALE_OPEN_WORKOUTS_ENABLED=true
JOB_CLOSE_STALE_OPEN_WORKOUTS_MAX_AGE_HOURS=24

# Observability
LOG_LEVEL=INFO
OTEL_ENABLED=false
OTEL_SERVICE_NAME=pe-be-backend
OTEL_SERVICE_VERSION=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_TRACES_SAMPLER_ARG=0.1
OTEL_EXCLUDED_URLS=/health

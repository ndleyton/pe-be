# Copy this file to backend/.env for local development.

# App
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
FRONTEND_POST_LOGIN_PATH=/auth/complete

# Security and session cookies
SECRET_KEY=replace-with-a-local-dev-secret
JWT_LIFETIME_SECONDS=604800
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=.example.com

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pe_be

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Optional external import database
IMPORT_DATABASE_HOST=localhost
IMPORT_DATABASE_PORT=5432
IMPORT_DATABASE_NAME=
IMPORT_DATABASE_USER=
IMPORT_DATABASE_PASSWORD=

# Optional app integrations
IMAGE_URL_PREFIX=https://images.example-cdn.com/exercises/

# Scheduled jobs
JOB_CHAT_ATTACHMENT_CLEANUP_ENABLED=true
JOB_EXERCISE_IMAGE_CLEANUP_ENABLED=true
JOB_CLOSE_STALE_OPEN_WORKOUTS_ENABLED=true
JOB_CLOSE_STALE_OPEN_WORKOUTS_MAX_AGE_HOURS=24
EXERCISE_IMAGE_UPLOAD_MAX_BYTES=5242880
EXERCISE_IMAGE_UPLOAD_MAX_COUNT_PER_TYPE=4
EXERCISE_IMAGE_UPLOAD_MAX_BYTES_PER_USER=104857600
EXERCISE_IMAGE_UPLOAD_MAX_PIXELS=16000000
EXERCISE_IMAGE_PUBLISHED_MAX_EDGE_PX=1600
EXERCISE_IMAGE_PUBLISHED_FORMAT=webp
EXERCISE_IMAGE_CLEANUP_BATCH_SIZE=25
EXERCISE_IMAGE_DELETED_RETENTION_DAYS=7
EXERCISE_IMAGE_REJECTED_RETENTION_DAYS=90
EXERCISE_IMAGE_ORPHAN_GRACE_HOURS=24

# Workout Photos
# WORKOUT_PHOTO_MAX_EDGE_PX=6000
# WORKOUT_PHOTO_MAX_PIXELS=16000000
# WORKOUT_PHOTO_OPTIMIZED_MAX_EDGE_PX=1600
# WORKOUT_PHOTO_OPTIMIZED_FORMAT=webp

# OpenTelemetry / OTLP
OTEL_ENABLED=false
OTEL_SERVICE_NAME=pe-be-backend
OTEL_SERVICE_VERSION=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
# Example: Authorization=Basic%20<base64(instance_id:token)>
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_TRACES_SAMPLER_ARG=0.1
OTEL_EXCLUDED_URLS=/health

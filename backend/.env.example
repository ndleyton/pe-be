DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/fitness_tracker
SECRET=your-secret-key
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Import database configuration (for external data sources)
IMPORT_DATABASE_HOST=localhost
IMPORT_DATABASE_PORT=5432
IMPORT_DATABASE_NAME=gym_tracker_development
IMPORT_DATABASE_USER=postgres
IMPORT_DATABASE_PASSWORD=your-import-db-password
# Image Configuration
IMAGE_URL_PREFIX=https://raw.githubusercontent.com/yuhonas/free-exercise-db/main/exercises/

# Cookie settings
COOKIE_SECURE=False
COOKIE_SAMESITE=lax

# The domain for which the authentication cookie is set. 
# In production, this should be your custom domain (e.g., personalbestie.com).
# In local development, this should be left unset.
# COOKIE_DOMAIN=